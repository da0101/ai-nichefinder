NICHEFINDER_ENV=development
NICHEFINDER_DB_URL=sqlite:///data/db/seo.db

GOOGLE_GEMINI_API_KEY=
SERPAPI_KEY=

GEMINI_FLASH_MODEL=gemini-2.5-flash
